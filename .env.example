# TermTalk Server Environment Configuration
# Copy this file to .env and edit as needed

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./termtalk.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/termtalk

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=termtalk-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# AWS S3 (optional - leave blank for local storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=termtalk-files

# Features
ENABLE_E2E_ENCRYPTION=true
